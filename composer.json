{
    "name": "psc-acme/registry-product",
    "description": "Package registry-product for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\RegistryProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "league/flysystem": "^3.0",
        "symfony/lock": "^7.0",
        "predis/predis": "^2.0",
        "aws/aws-sdk-php": "^3.332",
        "symfony/symfony": "^6.3",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "behat/behat": "^3.14",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}